# =========================================================================
# Fashion Stylist AI - Environment Variables Template
# =========================================================================
# ⚠️ 주의: 이 파일은 템플릿입니다. 실제 API 키는 이 파일에 작성하지 마시고,
# 이 파일을 복사하여 `.env` 파일을 생성한 뒤 그 곳에 입력해주세요.
# .env 파일은 Git에 업로드되지 않도록 .gitignore에 설정되어 있습니다.

# [OAuth 로그인 키] (Splash 화면의 소셜 로그인)
VITE_KAKAO_CLIENT_ID=your_kakao_rest_api_key_here
VITE_KAKAO_REDIRECT_URI=http://localhost:5173/oauth/kakao/callback
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/oauth/google/callback

# [AI 분석 엔진 키] (Style DNA 추출 및 추천 시스템 용)
VITE_OPENAI_API_KEY=sk-your_openai_api_key_here
# VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here (필요시)

# [백엔드 API 설정] (실제 DB 및 서버 연동 시)
VITE_API_BASE_URL=http://localhost:3000/api
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
